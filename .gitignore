# 参考项目，仅本地参考，不纳入版本控制
ref/

# 用户私有配置（含 API key 等敏感信息）；用 config.example.yaml 作模板
config.yaml
# 远程 SSH/sudo 凭据；只由 helix CLI 读取注入，绝不进大模型。用 config.secrets.example.yaml 作模板
config.secrets.yaml

# helix 运行时数据
.helix/
notes/
# 实验/复现工作区（方案、结果、拉回的产物）；用户数据，不进版本控制
experiments/
# 旧版工作区根目录名（migrate 后搬到 experiments/），一并忽略
repro/
# --draft 落的试跑工作区
draft_notes/
# migrate 补 config 字段前的备份
config.yaml.bak

# helix init 生成的本机软链（含绝对路径，每台机器自行 `helix init` 重建）
.claude/
.agents/
# AGENTS.md 是指向 CLAUDE.md 的软链（由 helix init 生成），规约单一真源在 CLAUDE.md
/AGENTS.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# 一次性维护脚本（如数据修复），跑完即删，不进版本控制
scripts/

# 缓存/临时
*.tmp
.DS_Store
